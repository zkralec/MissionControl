{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "openclaw_apply_draft_v1 payload",
  "type": "object",
  "required": ["pipeline_id", "upstream"],
  "properties": {
    "pipeline_id": {"type": "string", "minLength": 1},
    "upstream": {
      "type": "object",
      "required": ["task_id", "run_id", "task_type"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "task_type": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "request": {
      "type": "object",
      "properties": {
        "openclaw_apply_enabled": {"type": "boolean"},
        "openclaw_apply_capture_screenshots": {"type": "boolean"},
        "openclaw_apply_max_screenshots": {"type": "integer", "minimum": 0, "maximum": 20},
        "openclaw_apply_timeout_seconds": {"type": "integer", "minimum": 5, "maximum": 1200},
        "openclaw_allow_account_creation": {"type": "boolean"},
        "notify_channels": {"type": "array", "items": {"type": "string"}},
        "resume_upload_path": {"type": "string"},
        "profile_mode": {"type": "string"}
      },
      "additionalProperties": true
    },
    "draft_policy": {
      "type": "object",
      "properties": {
        "notify_channels": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "lineage": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": true
}
