{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "jobs_digest_v2 payload",
  "type": "object",
  "required": ["pipeline_id", "upstream", "request"],
  "properties": {
    "pipeline_id": {"type": "string", "minLength": 1},
    "upstream": {
      "type": "object",
      "required": ["task_id", "run_id", "task_type"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "task_type": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "request": {"type": "object", "additionalProperties": true},
    "artifact_base_url": {"type": "string"},
    "digest_policy": {
      "type": "object",
      "properties": {
        "max_items": {"type": "integer", "minimum": 1, "maximum": 10},
        "format": {"type": "string"},
        "notify_channels": {
          "type": "array",
          "items": {"type": "string"}
        },
        "notify_on_empty": {"type": "boolean"},
        "llm_enabled": {"type": "boolean"},
        "llm_max_retries": {"type": "integer", "minimum": 1, "maximum": 5},
        "strict_llm_output": {"type": "boolean"},
        "prompt_version": {"type": "string"},
        "artifact_base_url": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
