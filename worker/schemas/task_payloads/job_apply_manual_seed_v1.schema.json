{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "job_apply_manual_seed_v1 payload",
  "type": "object",
  "required": ["pipeline_id", "manual_job"],
  "properties": {
    "pipeline_id": {"type": "string", "minLength": 1},
    "manual_job": {
      "type": "object",
      "required": ["title", "company", "source", "source_url", "application_url"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "company": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "source_url": {"type": "string", "minLength": 1},
        "application_url": {"type": "string", "minLength": 1},
        "job_id": {"type": "string"},
        "normalized_job_id": {"type": "string"}
      },
      "additionalProperties": true
    },
    "request": {"type": "object", "additionalProperties": true},
    "prepare_policy": {
      "type": "object",
      "properties": {
        "include_cover_letter": {"type": "boolean"},
        "enqueue_openclaw_apply": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "lineage": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": true
}
