{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "jobs_shortlist_v1 payload",
  "type": "object",
  "required": ["pipeline_id", "upstream", "request"],
  "properties": {
    "pipeline_id": {"type": "string", "minLength": 1},
    "upstream": {
      "type": "object",
      "required": ["task_id", "run_id", "task_type"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "task_type": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "request": {"type": "object", "additionalProperties": true},
    "shortlist_policy": {
      "type": "object",
      "properties": {
        "max_items": {"type": "integer", "minimum": 1, "maximum": 100},
        "min_score": {"type": ["number", "integer"]},
        "per_source_cap": {"type": "integer", "minimum": 1, "maximum": 50},
        "diversity_mode": {"type": "string"},
        "per_company_cap": {"type": "integer", "minimum": 1, "maximum": 10},
        "source_diversity_weight": {"type": ["number", "integer"]},
        "company_repetition_penalty": {"type": ["number", "integer"]},
        "near_duplicate_title_similarity_threshold": {"type": ["number", "integer"]},
        "freshness_weight_enabled": {"type": "boolean"},
        "freshness_max_bonus": {"type": ["number", "integer"]}
      },
      "additionalProperties": true
    },
    "digest_policy": {
      "type": "object",
      "properties": {
        "max_items": {"type": "integer", "minimum": 1, "maximum": 100},
        "format": {"type": "string"},
        "notify_channels": {
          "type": "array",
          "items": {"type": "string"}
        },
        "notify_on_empty": {"type": "boolean"},
        "llm_enabled": {"type": "boolean"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
