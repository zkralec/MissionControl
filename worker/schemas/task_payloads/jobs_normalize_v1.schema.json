{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "jobs_normalize_v1 payload",
  "type": "object",
  "required": ["pipeline_id", "upstream", "request"],
  "properties": {
    "pipeline_id": {"type": "string", "minLength": 1},
    "upstream": {
      "type": "object",
      "required": ["task_id", "run_id", "task_type"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "task_type": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "request": {"type": "object", "additionalProperties": true},
    "normalization_policy": {
      "type": "object",
      "properties": {
        "dedupe_keys": {
          "type": "array",
          "items": {"type": "string"}
        },
        "canonicalization_version": {"type": "string"},
        "dedupe_strategy": {"type": "string"},
        "fuzzy_matching": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "threshold": {"type": ["number", "integer"]},
            "ambiguous_threshold": {"type": ["number", "integer"]}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "rank_policy": {
      "type": "object",
      "properties": {
        "weights": {"type": "object", "additionalProperties": {"type": ["number", "integer"]}},
        "max_ranked": {"type": "integer", "minimum": 1, "maximum": 200},
        "llm_enabled": {"type": "boolean"},
        "prompt_version": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
