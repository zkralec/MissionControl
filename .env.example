POSTGRES_USER=mission
POSTGRES_PASSWORD=mission
POSTGRES_DB=mission_control
DATABASE_URL=postgresql+psycopg://mission:mission@postgres:5432/mission_control
REDIS_URL=redis://redis:6379/0
TASK_RUN_HISTORY_DB_PATH=/data/task_run_history.sqlite3
AI_USAGE_DB_PATH=/data/task_run_history.sqlite3
EVENT_LOG_DB_PATH=/data/task_run_history.sqlite3
SYSTEM_METRICS_DB_PATH=/data/task_run_history.sqlite3
AGENT_HEARTBEAT_DB_PATH=/data/task_run_history.sqlite3
CANDIDATE_PROFILE_DB_PATH=/data/task_run_history.sqlite3
DAILY_OPS_REPORT_DB_PATH=/data/task_run_history.sqlite3

DAILY_BUDGET_USD=1.00
BUDGET_BUFFER_USD=0.02
MISSION_CONTROL_DAY_BOUNDARY_TZ=America/New_York
OPENAI_MIN_COST_USD=0.01
RETRY_BASE_SECONDS=30
RETRY_MAX_SECONDS=900
RQ_JOB_TIMEOUT_SECONDS=900
ORPHANED_RUN_RECOVERY_ENABLED=true
ORPHANED_RUN_STALE_AFTER_SEC=300
ORPHANED_RUN_RECOVERY_INTERVAL_SEC=60

USE_LLM=true
JOBS_DIGEST_LLM_MAX_RETRIES_DEFAULT=1
OPENAI_API_KEY=sk-...
RATE_LIMIT_CREATE_CAPACITY=120
RATE_LIMIT_CREATE_REFILL_PER_SEC=2.0
SCHEDULER_INTERVAL_SEC=60
SCHEDULER_NAME=scheduler
WORKER_NAME=worker
HEARTBEAT_TRACKED_AGENTS=scheduler,worker
WATCHDOG_TRACKED_AGENTS=scheduler,worker
WORKER_HEARTBEAT_ENABLED=true
WORKER_INLINE_HEARTBEAT_ENABLED=false
WORKER_HEARTBEAT_INTERVAL_SEC=15
WATCHDOG_ENABLED=true
WATCHDOG_STALE_AFTER_SEC=240
WATCHDOG_WARNING_COOLDOWN_SEC=600
WATCHDOG_ENABLE_RESTART=false
WATCHDOG_RESTART_MIN_BACKOFF_SEC=60
WATCHDOG_RESTART_MAX_BACKOFF_SEC=3600
AGENT_HEARTBEAT_RETENTION_SEC=604800
AGENT_HEARTBEAT_PRUNE_INTERVAL_SEC=3600
DAILY_OPS_REPORT_ENABLED=true
DAILY_OPS_REPORT_RUN_HOUR_UTC=0
DAILY_OPS_REPORT_NOTIFY_CHANNELS=
DAILY_OPS_REPORT_NOTIFY_TTL_SEC=172800
AUTONOMOUS_PLANNER_ENABLED=false
AUTONOMOUS_PLANNER_INTERVAL_SEC=300
AUTONOMOUS_PLANNER_EXECUTE=false
AUTONOMOUS_PLANNER_REQUIRE_APPROVAL=true
AUTONOMOUS_PLANNER_APPROVED=false
AUTONOMOUS_PLANNER_MAX_CREATE_PER_CYCLE=1
AUTONOMOUS_PLANNER_MAX_EXECUTE_PER_CYCLE=2
AUTONOMOUS_PLANNER_MAX_PENDING_TASKS=20
AUTONOMOUS_PLANNER_FAILURE_LOOKBACK_MINUTES=60
AUTONOMOUS_PLANNER_FAILURE_ALERT_COUNT_THRESHOLD=5
AUTONOMOUS_PLANNER_FAILURE_ALERT_RATE_THRESHOLD=0.5
AUTONOMOUS_PLANNER_STALE_TASK_AGE_SECONDS=180
AUTONOMOUS_PLANNER_EXECUTE_TASK_COOLDOWN_SECONDS=600
AUTONOMOUS_PLANNER_HEALTH_CPU_MAX_PERCENT=90
AUTONOMOUS_PLANNER_HEALTH_MEMORY_MAX_PERCENT=90
AUTONOMOUS_PLANNER_HEALTH_DISK_MAX_PERCENT=95
AUTONOMOUS_PLANNER_COST_BUDGET_USD=
AUTONOMOUS_PLANNER_TOKEN_BUDGET=
AUTONOMOUS_PLANNER_CREATE_TASK_TYPE=
AUTONOMOUS_PLANNER_CREATE_PAYLOAD_JSON=
AUTONOMOUS_PLANNER_CREATE_TASK_MODEL=
AUTONOMOUS_PLANNER_CREATE_TASK_MAX_ATTEMPTS=3
AUTONOMOUS_PLANNER_CREATE_TASK_COOLDOWN_SECONDS=1800
PLANNER_CONTROL_DB_PATH=/data/task_run_history.sqlite3
PLANNER_CONTROL_API_ENABLED=true
PLANNER_CONTROL_API_URL=http://api:8000
PLANNER_CONTROL_API_TIMEOUT_SEC=2.5
UNICORN_MAX_ITEMS_IN_MESSAGE=5
UNICORN_NOTIFY_SEVERITY=info
UNICORN_5090_GPU_MAX_PRICE=2000
UNICORN_5090_PC_MAX_PRICE=4000
DEAL_ALERT_STATE_DB_PATH=/data/task_run_history.sqlite3
DEAL_ALERT_COOLDOWN_SECONDS=21600
DEAL_ALERT_MATERIAL_PRICE_CHANGE_PCT=3
DEAL_ALERT_MATERIAL_PRICE_CHANGE_ABS_USD=25
SCRAPE_TIMEOUT_SECONDS=15
SCRAPE_CACHE_TTL_SECONDS=120
SCRAPE_RATE_LIMIT_SECONDS=2
SCRAPE_RETRY_ATTEMPTS=3
OPENCLAW_ENABLED=false
OPENCLAW_COLLECTOR_COMMAND=
OPENCLAW_COMMAND_TIMEOUT_SECONDS=180
OPENCLAW_APPLY_DRAFT_ENABLED=false
OPENCLAW_APPLY_DRAFT_COMMAND=
OPENCLAW_APPLY_TOOL_COMMAND=python /app/scripts/openclaw_apply_tool_bridge.py
# OPENCLAW_APPLY_TOOL_COMMAND is the stable bridge entrypoint; browser subcommands are appended by the backend to OPENCLAW_BROWSER_BASE_COMMAND.
OPENCLAW_APPLY_BROWSER_COMMAND=python /app/scripts/openclaw_apply_browser_backend.py
OPENCLAW_APPLY_BROWSER_ATTACH_MODE=true
OPENCLAW_APPLY_SKIP_BROWSER_START=true
OPENCLAW_APPLY_ALLOW_BROWSER_START=false
OPENCLAW_APPLY_RUN_ON_HOST=false
OPENCLAW_APPLY_GATEWAY_URL=ws://host.docker.internal:18789
OPENCLAW_APPLY_GATEWAY_TOKEN=CHANGE_ME
OPENCLAW_APPLY_CDP_URL=http://host.docker.internal:9222
OPENCLAW_APPLY_HOST_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_APPLY_HOST_CDP_URL=http://127.0.0.1:18800
OPENCLAW_APPLY_HOST_GATEWAY_ALIAS=host.docker.internal
OPENCLAW_BROWSER_BASE_COMMAND=/opt/openclaw/npm-global/bin/openclaw browser --url ws://host.docker.internal:18789 --token CHANGE_ME
# OPENCLAW_BROWSER_BASE_COMMAND is only the base prefix. The runner/backend appends status, tabs, open, snapshot, screenshot, fill, and upload.
OPENCLAW_APPLY_TIMEOUT_SECONDS=240
OPENCLAW_APPLY_MAX_STEPS=24
OPENCLAW_APPLY_INSPECT_ONLY=false
APPLICATION_DRAFT_STATE_DB_PATH=/data/task_run_history.sqlite3
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=
DISCORD_AVATAR_URL=
NOTIFY_DISCORD_ALLOWLIST=deals_scan_v1,unicorn_deals_poll_v1,unicorn_deals_rank_v1,jobs_digest_v2,openclaw_apply_draft_v1,ops_report_v1
NOTIFY_DEDUPE_TTL_SECONDS=21600
NOTIFY_DEV_MODE=false
